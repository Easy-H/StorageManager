rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // [Helper] 조직이 활성 상태인지 확인하는 함수
    function isOrgActive(orgId) {
      return get(/databases/$(database)/documents/organizations/$(orgId)).data.isActive == true;
    }
    
    function isOrgAdmin(orgId) {
    	return get(/databases/$(database)/documents/organizations/$(orgId)/members/$(request.auth.uid)).data.level == 100;
    }
    
    function isOrgMember(orgId) {
    	return exists(/databases/$(database)/documents/organizations/$(orgId)/members/$(request.auth.uid));
    }

    // [1] 사용자 정보
    match /users/{userId} {
      allow read, create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && request.auth.uid == userId;

      match /organizations/{orgId} {
        // 읽기는 본인만 가능하지만, 조직이 활성 상태일 때만 가능하게 제한 가능
        allow read: if request.auth != null && request.auth.uid == userId;
        allow create: if request.auth != null && request.auth.uid == userId;
        
        // 수정 권한: 해당 조직의 관리자(level 100)만 타인의 레벨 수정 가능
        allow update: if request.auth != null && 
          isOrgAdmin(orgId);
        allow delete: if request.auth != null &&
        	(isOrgAdmin(orgId) || request.auth.uid == userId);
      }
    }

    // [2] 조직 정보
    match /organizations/{orgId} {
      // 조직 생성 및 조회
      allow create: if request.auth != null;
      // get/list는 활성 상태인 조직만 허용
      allow get, list: if request.auth != null && resource.data.isActive == true;
      
      // 관리자(level 100)만 조직 정보 수정(isActive 포함) 및 삭제 가능
      allow update, delete: if request.auth != null &&
        isOrgAdmin(orgId);

      // 하위 멤버 규칙
      match /members/{memberUid} {
        allow create: if request.auth != null && request.auth.uid == memberUid;
        // 조직이 Active할 때만 읽기/쓰기 허용 (본인 또는 관리자)
        allow read, write: if request.auth != null && isOrgActive(orgId) && (
          request.auth.uid == memberUid || isOrgAdmin(orgId)
        );
      }

      // 하위 데이터 (상품, 로그 등)
      match /products/{productId} {
        allow read, write: if request.auth != null && isOrgActive(orgId) &&
          isOrgMember(orgId);
      }

      match /inventory_logs/{logId} {
        allow read, write: if request.auth != null && isOrgActive(orgId) &&
          isOrgMember(orgId);
      }
      
      match /todos/{todoId} {
      	allow read, write, update, delete;
      }
    }
  }
}